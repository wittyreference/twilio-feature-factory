  "adaptation_types": {
    "frontmatter": "Add YAML frontmatter block with name and description fields",
    "frontmatter-agent": "Add YAML frontmatter with name, description, and model: opus",
    "strip-mcp": "Remove MCP tool references (validate_call, etc.), replace with CLI alternatives",
    "strip-factory-paths": "Remove references to functions/, agents/, .claude/, .meta/ internal paths",
    "strip-meta-mode": "Remove _meta-mode.sh sourcing and CLAUDE_META_MODE checks",
    "strip-flywheel": "Remove flywheel-doc-check.sh calls and pending-actions integration",
    "strip-auto-clear": "Remove auto-clear pending actions section from pre-commit flow",
    "strip-compact": "Remove compact-pending marker detection and processing",
    "strip-team-refs": "Remove /team references and Agent Teams mentions",
    "rewrite-meta-conditional": "AI rewrites .meta conditional blocks for plugin context (removes meta-mode routing, replaces .meta paths with plugin equivalents)",
    "generalize-agents": "Replace factory-specific agent names with generic terms",
    "generalize-role": "Rewrite from factory command perspective to portable agent perspective",
    "generalize-names": "Replace hardcoded project names with dynamic values (e.g., path.basename(cwd))",
    "extract-invariants": "DEPRECATED — invariants moved to .claude/rules/*-invariants.md",
    "merge-invariant-rules": "Concatenate all *-invariants.md rules files (primary + additional_sources) into one plugin skill, stripping paths: frontmatter",
    "restructure": "Significant structural changes beyond simple stripping",
    "simplify": "Reduce to core functionality, removing factory-specific checks",
    "minimal": "Little or no adaptation needed, near-identical copy"
  }
