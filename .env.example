# ============================================================================
# Twilio Feature Factory — Environment Configuration
#
# QUICK START: Copy this file to .env and fill in the two required values.
# Everything else is optional — uncomment and configure as you provision
# each service. Lines left commented out won't interfere with auth.
#
# WARNING: Uncommented placeholder values (like SKxxxx) WILL cause auth
# failures. Only uncomment a line when you have a real value for it.
#
# If you already have TWILIO_* env vars in your shell (from .zshrc,
# another project, or Twilio CLI), they will silently override these values.
# Use direnv (see README step 4) or run: ./scripts/env-doctor.sh to check.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# These two are the only values you need to get started.
# Find them at https://console.twilio.com/

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ── Phone Number (required for most features) ───────────────────────────────
# Purchase at https://console.twilio.com/us1/develop/phone-numbers
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── API Key Auth (optional, recommended for production) ──────────────────────
# Create at https://console.twilio.com/us1/account/keys-credentials/api-keys
# TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_SECRET=your_api_secret_here

# ── Service SIDs (uncomment as you provision each service) ───────────────────
# Run `npm run setup` to provision interactively, or create manually in Console.

# Verify Service — phone verification / 2FA
# https://console.twilio.com/us1/develop/verify/services
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sync Service — real-time state synchronization
# https://console.twilio.com/us1/develop/sync/services
# TWILIO_SYNC_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TaskRouter — skills-based routing
# https://console.twilio.com/us1/develop/taskrouter/workspaces
# TWILIO_TASKROUTER_WORKSPACE_SID=WSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TASKROUTER_WORKFLOW_SID=WWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Messaging Service — sender pools and A2P compliance
# https://console.twilio.com/us1/develop/sms/services
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voice SDK TwiML App — browser-based softphone
# Create via: twilio api:core:applications:create --friendly-name "Voice SDK"
# TWILIO_VOICE_SDK_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Testing ──────────────────────────────────────────────────────────────────

# Recipient number for E2E tests
# TEST_PHONE_NUMBER=+1xxxxxxxxxx

# Conference testing numbers (distinct numbers for multi-party call tests)
# CONFERENCE_HOST_NUMBER=+1xxxxxxxxxx
# CONFERENCE_PARTICIPANT_1=+1xxxxxxxxxx
# CONFERENCE_PARTICIPANT_2=+1xxxxxxxxxx

# ── Voice AI / ConversationRelay ─────────────────────────────────────────────

# WebSocket URL for ConversationRelay agent
# CONVERSATION_RELAY_URL=wss://your-websocket-server.com/relay

# Anthropic API Key — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ── Webhooks ─────────────────────────────────────────────────────────────────

# Status callback and fallback URLs (set by npm run setup after deploy)
# TWILIO_STATUS_CALLBACK_URL=https://your-domain.twil.io/callbacks/call-status
# TWILIO_FALLBACK_URL=https://your-domain.twil.io/callbacks/fallback
# TWILIO_CALLBACK_BASE_URL=https://your-domain.twil.io

# ── ngrok (for local development and agent-to-agent testing) ─────────────────

# Agent-to-agent testing requires two separate ngrok domains
# Create domains at https://dashboard.ngrok.com/domains
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# NGROK_DOMAIN_A=your-domain-a.ngrok.dev
# NGROK_DOMAIN_B=your-domain-b.ngrok.io

# ── Regional (DO NOT uncomment unless actively testing regions) ──────────────
# The Twilio SDK auto-reads these from process.env. Setting them routes ALL
# API calls to regional endpoints. US1 auth tokens fail with 401 on regional
# endpoints. See: ./scripts/env-doctor.sh
# TWILIO_REGION=
# TWILIO_EDGE=
