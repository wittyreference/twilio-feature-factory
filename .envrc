# ABOUTME: direnv environment configuration for twilio-feature-factory.
# ABOUTME: Provides environment isolation by unsetting inherited Twilio vars before loading project .env.
#
# NOTE: This file is INERT unless direnv is installed and hooked into your shell.
# Without direnv, none of the unset commands below execute, and shell env vars
# from other projects will silently override your .env values.
#
# Install: brew install direnv
# Hook:    echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
# Allow:   direnv allow .

# --- Step 1: Unset ALL known Twilio env vars that could leak from parent shell ---
# Without this, existing shell vars (from .zshrc, another project, Twilio CLI)
# persist and silently override .env values because dotenv's default mode
# does NOT override existing process.env values.

# Core credentials (most common conflict source)
unset TWILIO_ACCOUNT_SID
unset TWILIO_AUTH_TOKEN
unset TWILIO_API_KEY
unset TWILIO_API_SECRET

# Regional routing (silent killers — SDK auto-reads these from process.env)
unset TWILIO_REGION
unset TWILIO_EDGE

# Phone numbers and service SIDs
unset TWILIO_PHONE_NUMBER
unset TWILIO_VERIFY_SERVICE_SID
unset TWILIO_SYNC_SERVICE_SID
unset TWILIO_TASKROUTER_WORKSPACE_SID
unset TWILIO_TASKROUTER_WORKFLOW_SID
unset TWILIO_MESSAGING_SERVICE_SID
unset TWILIO_VOICE_SDK_APP_SID

# Callback and status URLs
unset TWILIO_STATUS_CALLBACK_URL
unset TWILIO_FALLBACK_URL
unset TWILIO_CALLBACK_BASE_URL

# Test numbers
unset TEST_PHONE_NUMBER
unset CONFERENCE_HOST_NUMBER
unset CONFERENCE_PARTICIPANT_1
unset CONFERENCE_PARTICIPANT_2

# --- Step 2: Load project .env if it exists ---
dotenv_if_exists
