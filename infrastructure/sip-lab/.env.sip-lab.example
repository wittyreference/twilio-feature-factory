# ABOUTME: Environment template for SIP Lab droplet and Twilio SIP trunk config.
# ABOUTME: Copy to .env.sip-lab — most values set automatically by setup scripts.
# SIP Lab — Environment Variables
# Copy to .env.sip-lab and fill in values.
# Most values are set automatically by droplet-setup.sh and setup-sip-lab.js.

# DigitalOcean Resources (set by droplet-setup.sh)
DO_DROPLET_ID=
DO_FIREWALL_ID=
DO_SSH_KEY_ID=
DO_SNAPSHOT_ID=
SIP_LAB_DROPLET_IP=
SIP_LAB_SSH_KEY=~/.ssh/sip-lab

# Docker environment (used by docker-compose.yml via .env.sip-lab on droplet)
TWILIO_TRUNK_DOMAIN=              # Set by setup-sip-lab.js
SIP_CREDENTIAL_USERNAME=          # Set by setup-sip-lab.js
SIP_CREDENTIAL_PASSWORD=          # Set by setup-sip-lab.js
EXTERNAL_IP=                      # Set to droplet public IP
LOCAL_NET=10.0.0.0/8

# Twilio SIP Resources (set by setup-sip-lab.js)
SIP_LAB_TRUNK_SID=
SIP_LAB_TRUNK_DOMAIN=
SIP_LAB_IP_ACL_SID=
SIP_LAB_IP_ADDRESS_SID=
SIP_LAB_CREDENTIAL_LIST_SID=
SIP_LAB_CREDENTIAL_SID=
SIP_LAB_ORIGINATION_URL_SID=
SIP_LAB_PHONE_NUMBER_SID=
