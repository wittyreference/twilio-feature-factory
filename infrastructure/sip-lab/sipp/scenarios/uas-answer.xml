<!--
  ABOUTME: SIPp UAS scenario that answers an incoming INVITE and stays connected.
  ABOUTME: Used to test outbound calls from Asterisk — acts as the remote endpoint.
-->
<?xml version="1.0" encoding="ISO-8859-1" ?>
<scenario name="Basic UAS Answer">

  <!-- Receive INVITE -->
  <recv request="INVITE" crlf="true" />

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port]>
      Content-Length: 0
    ]]>
  </send>

  <pause milliseconds="1000" />

  <!-- Send 200 OK with SDP -->
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=sipp 1 1 IN IP[local_ip_type] [local_ip]
      s=SIPp UAS
      c=IN IP[local_ip_type] [local_ip]
      t=0 0
      m=audio [auto_media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
    ]]>
  </send>

  <!-- Receive ACK -->
  <recv request="ACK" optional="true" crlf="true" />

  <!-- Stay connected for call duration -->
  <pause milliseconds="10000" />

  <!-- Receive BYE -->
  <recv request="BYE" />

  <!-- Send 200 OK to BYE -->
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

</scenario>
