{
  "name": "twilio-feature-factory",
  "version": "1.0.0",
  "description": "Twilio CPaaS prototyping template optimized for Claude Code",
  "main": "index.js",
  "scripts": {
    "postinstall": "cd agents/mcp-servers/twilio && npm install && npm run build",
    "setup": "node scripts/setup.js",
    "bootstrap": "./scripts/bootstrap.sh",
    "smoke-test": "./scripts/bootstrap.sh --check-only",
    "test": "jest --testPathPattern='__tests__/(unit|integration)/'",
    "test:watch": "jest --watch --testPathPattern='__tests__/(unit|integration)/'",
    "test:coverage": "jest --coverage --testPathPattern='__tests__/(unit|integration)/'",
    "test:e2e": "newman run postman/collection.json -e postman/environment.json --timeout-request 5000",
    "test:voice-sdk": "npx playwright test --project=voice-sdk",
    "test:voice-sdk:headed": "npx playwright test --project=voice-sdk --headed",
    "test:video-sdk": "npx playwright test --project=video-sdk",
    "test:video-sdk:headed": "npx playwright test --project=video-sdk --headed",
    "test:all": "npm test && npm run test:e2e",
    "prestart": "./scripts/env-doctor.sh || echo '\\n  Environment issues detected. See above. Continuing anyway...\\n'",
    "start": "twilio serverless:start",
    "start:ngrok": "twilio serverless:start --ngrok",
    "deploy:dev": "twilio serverless:deploy --environment dev",
    "deploy:prod": "twilio serverless:deploy --environment production",
    "lint": "eslint functions/ __tests__/",
    "lint:fix": "eslint functions/ __tests__/ --fix",
    "demo": "./scripts/demo.sh",
    "test:e2e:deployed": "newman run postman/collection.json -e postman/environment-deployed.json --timeout-request 10000",
    "test:sip-lab": "./scripts/run-sip-lab-e2e.sh"
  },
  "keywords": [
    "twilio",
    "serverless",
    "prototype",
    "claude-code",
    "voice",
    "sms",
    "messaging",
    "verify"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@twilio-labs/serverless-runtime-types": "^4.0.0",
    "@twilio/voice-sdk": "^2.18.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "newman": "^6.1.0",
    "twilio-run": "^5.0.0",
    "twilio-video": "^2.34.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": "^20.x || ^22.x"
  }
}
